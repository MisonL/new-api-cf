{
  "name": "new-api-cf",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun run --cwd apps/admin-web dev",
    "dev:edge": "bun run --cwd apps/edge-api dev",
    "check:web": "bun run --cwd apps/admin-web check",
    "deploy:edge": "bun run --cwd apps/edge-api deploy",
    "types:edge": "bun run --cwd apps/edge-api types",
    "check:shared": "bun run --cwd packages/shared check",
    "check:edge": "bun run --cwd apps/edge-api check",
    "check": "bun run types:edge && bun run check:shared && bun run check:edge && bun run check:web",
    "integration:assistants": "bun run --cwd apps/edge-api integration:assistants",
    "integration:realtime": "bun run --cwd apps/edge-api integration:realtime",
    "integration:responses": "bun run --cwd apps/edge-api integration:responses",
    "integration:fine-tuning": "bun run --cwd apps/edge-api integration:fine-tuning",
    "integration:vector-stores": "bun run --cwd apps/edge-api integration:vector-stores",
    "integration:uploads": "bun run --cwd apps/edge-api integration:uploads",
    "integration:files": "bun run --cwd apps/edge-api integration:files",
    "integration:batches": "bun run --cwd apps/edge-api integration:batches",
    "integration:threads-runs": "bun run --cwd apps/edge-api integration:threads-runs",
    "integration:core-relay": "bun run --cwd apps/edge-api integration:core-relay",
    "integration:conversations": "bun run --cwd apps/edge-api integration:conversations",
    "integration:all": "bun run --cwd apps/edge-api integration:all"
  }
}
